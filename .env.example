# cult-ui-pro registry key — referenced by components.json (X-API-Key).
# Used ONLY at build/install time by `shadcn add @cult-ui-pro/...`.
# Copy this file to .env.local and fill in the real value (do NOT commit .env.local).
CULT_UI_PRO_API_KEY=

# Contact form delivery — used by app/api/contact/route.ts (Vercel serverless).
# Create a free form at https://formspree.io with notifications going to your
# inbox (msl@lnad-med.science), then paste its endpoint URL below. Add this in
# Vercel → Project → Settings → Environment Variables, and to .env.local.
# Example: https://formspree.io/f/xxxxxxxx
FORMSPREE_ENDPOINT=
