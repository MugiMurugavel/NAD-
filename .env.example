# cult-ui-pro registry key — referenced by components.json (X-API-Key).
# Used ONLY at build/install time by `shadcn add @cult-ui-pro/...`.
# Copy this file to .env.local and fill in the real value (do NOT commit .env.local).
CULT_UI_PRO_API_KEY=

# Contact form delivery — used by app/api/contact/route.ts (Vercel serverless).
# Get a key at https://resend.com (free tier). Add these in Vercel → Project →
# Settings → Environment Variables, and to .env.local for local dev.
RESEND_API_KEY=
# Where inquiries are delivered (your inbox):
CONTACT_TO_EMAIL=
# Verified sender. Until you verify lnad-med.science in Resend, leave blank to
# use Resend's test sender (onboarding@resend.dev). Example once verified:
#   "Cell Context <msl@lnad-med.science>"
CONTACT_FROM_EMAIL=
